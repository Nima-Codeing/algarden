// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========== Enum ==========
// 記録期間
enum GardenPeriod {
  MONTHLY
}

enum SeedType {
  TENDRIL
}

enum GrowthStage {
  SPROUT
  YOUNG
  MATURE
  BLOOM
}

enum TodoScore {
  S
  A
  B
  C
  D
}

enum MutationType {
  OCTAHEDRON // 八面体
  RADIAL // 放射
}

// ========== Model ==========
model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  todos     Todo[] // 全期間のtodo
  gardens   Garden[]
  createdAt DateTime @default(now()) @db.Timestamptz(0)
}

model Garden {
  id           String       @id @default(uuid()) @db.Uuid
  snapshotUrl  String? // v2: スクリーンショット保存用
  isActive     Boolean      @default(true)
  periodType   GardenPeriod
  todos        Todo[] // この期間に作ったTodoという概念
  plants       Plant[] // Garden内の全ネットワークを保持
  plantedSeeds Seed[]
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime     @default(now()) @db.Timestamptz(0)
  endedAt      DateTime?    @db.Timestamptz(0) // 期間終了時に日付格納
  updatedAt    DateTime     @updatedAt @db.Timestamptz(0)
  createdAt    DateTime     @default(now()) @db.Timestamptz(0)
}

model Todo {
  id             String      @id @default(uuid()) @db.Uuid
  title          String      @db.VarChar(30)
  isCompleted    Boolean     @default(false)
  targetDuration Int? // 目標時間(秒)
  score          TodoScore?
  plantNodes     PlantNode[] // Todoから生成された概念
  userId         String      @db.Uuid
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gardenId       String      @db.Uuid
  garden         Garden      @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  startedAt      DateTime?   @db.Timestamptz(0)
  completedAt    DateTime?   @db.Timestamptz(0)
  createdAt      DateTime    @default(now()) @db.Timestamptz(0)
}

model Seed {
  id        String    @id @default(uuid()) @db.Uuid
  x         Float?
  y         Float?
  seedType  SeedType  @default(TENDRIL)
  isPlanted Boolean   @default(false)
  plant     Plant? // Seedを植えたらPlantが生成される
  gardenId  String    @db.Uuid
  garden    Garden    @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  plantedAt DateTime? @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @db.Timestamptz(0)
}

model Plant {
  id          String      @id @default(uuid()) @db.Uuid
  nodeCount   Int         @default(1) // Seed植え付け時のルートノード含む
  growthStage GrowthStage @default(SPROUT)
  plantNodes  PlantNode[]
  plantEdges  PlantEdge[]
  gardenId    String      @db.Uuid
  garden      Garden      @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  seedId      String      @unique @db.Uuid
  seed        Seed        @relation(fields: [seedId], references: [id], onDelete: Cascade)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(0)
  createdAt   DateTime    @default(now()) @db.Timestamptz(0)
}

model PlantNode {
  id                String        @id @default(uuid()) @db.Uuid
  hue               Float
  size              Float
  depth             Int
  angle             Float? // 親ノードからの角度
  length            Float? // 親ノードから自ノードまでの距離
  mutationType      MutationType? // ノードが持つ変異遺伝子
  mutationProgress  Int           @default(0) // 変異設計図の進捗度
  mutationBlueprint Json?         @db.JsonB // 設計図のJSON
  canSpawn          Boolean       @default(true)
  children          PlantNode[]   @relation("ParentChildren")
  edgesFrom         PlantEdge[]   @relation("EdgeFrom")
  edgesTo           PlantEdge[]   @relation("EdgeTo")
  parentId          String?       @db.Uuid
  // NoAction: PostgreSQLの循環的Cascade禁止のため。Plant削除時はplantIdのCascadeで全Node削除される
  parent            PlantNode?    @relation("ParentChildren", fields: [parentId], references: [id], onDelete: NoAction)
  todoId            String?       @db.Uuid
  todo              Todo?         @relation(fields: [todoId], references: [id], onDelete: Cascade)
  plantId           String        @db.Uuid
  plant             Plant         @relation(fields: [plantId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now()) @db.Timestamptz(0)
}

model PlantEdge {
  id        String    @id @default(uuid()) @db.Uuid
  plantId   String    @db.Uuid
  plant     Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  fromId    String    @db.Uuid
  from      PlantNode @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId      String    @db.Uuid
  to        PlantNode @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @db.Timestamptz(0)
}

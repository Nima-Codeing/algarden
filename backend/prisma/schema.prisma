// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========== Enum ==========
// 記録期間
enum GardenPeriod {
  MONTHLY
}

enum SeedType {
  DFS
}

enum GrowthStage {
  SPROUT
  YOUNG
  MATURE
  BLOOM
}

// ========== Model ==========
model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  todos     Todo[] // 全期間のtodo
  gardens   Garden[]
  createdAt DateTime @default(now()) @db.Timestamptz(0)
}

model Garden {
  id           String       @id @default(uuid()) @db.Uuid
  snapshotUrl  String?
  isActive     Boolean      @default(true)
  periodType   GardenPeriod
  todos        Todo[] // この期間に作ったTodoという概念
  plantedSeeds Seed[]
  plants       Plant[] // Garden内の全ネットワークを保持
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime     @default(now()) @db.Timestamptz(0)
  endedAt      DateTime?    @db.Timestamptz(0) // 期間終了時に日付格納
  updatedAt    DateTime     @updatedAt @db.Timestamptz(0)
  createdAt    DateTime     @default(now()) @db.Timestamptz(0)
}

model Todo {
  id          String      @id @default(uuid()) @db.Uuid
  title       String      @db.VarChar(30)
  isCompleted Boolean     @default(false)
  plantNodes  PlantNode[] // Todoから生成された概念
  userId      String      @db.Uuid
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gardenId    String      @db.Uuid
  garden      Garden      @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  completedAt DateTime?   @db.Timestamptz(0)
  createdAt   DateTime    @default(now()) @db.Timestamptz(0)
}

model Seed {
  id        String    @id @default(uuid()) @db.Uuid
  px        Float
  py        Float
  isPlanted Boolean   @default(false)
  seedType  SeedType
  plant     Plant? // Seedを植えたらPlantが生成される
  gardenId  String    @db.Uuid
  garden    Garden    @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  plantedAt DateTime? @db.Timestamptz(0)
  createdAt DateTime  @default(now()) @db.Timestamptz(0)
}

model Plant {
  id          String      @id @default(uuid()) @db.Uuid
  growthStage GrowthStage @default(SPROUT)
  nodeCount   Int         @default(1) // Seed植え付け時のルートノード含む
  plantNodes  PlantNode[]
  gardenId    String      @db.Uuid
  garden      Garden      @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  seedId      String      @unique @db.Uuid
  seed        Seed        @relation(fields: [seedId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now()) @db.Timestamptz(0)
}

model PlantNode {
  id        String      @id @default(uuid()) @db.Uuid
  hue       Float
  size      Float
  angle     Float
  length    Float // 親ノードから自ノードまでの距離
  depth     Int         @default(0)
  parentId  String?     @db.Uuid
  parent    PlantNode?  @relation("ParentChildren", fields: [parentId], references: [id], onDelete: NoAction)
  // NoAction: PostgreSQLの循環的Cascade禁止のため。Plant削除時はplantIdのCascadeで全Node削除される
  children  PlantNode[] @relation("ParentChildren")
  todoId    String?     @db.Uuid
  todo      Todo?       @relation(fields: [todoId], references: [id], onDelete: Cascade)
  plantId   String      @db.Uuid
  plant     Plant       @relation(fields: [plantId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now()) @db.Timestamptz(0)
}
